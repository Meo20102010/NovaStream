NODE_ENV=production
PORT=3000
HOST=0.0.0.0

DATABASE_URL=postgresql://user:password@localhost:5432/novastream

JWT_SECRET=change-this-to-a-secure-random-string-at-least-32-chars
JWT_EXPIRES_IN=7d

STORAGE_PATH=./storage
MAX_FILE_SIZE=10737418240
CHUNK_SIZE=5242880

UPLOAD_DIR=./storage/uploads
THUMBNAIL_DIR=./storage/thumbnails
POSTER_DIR=./storage/posters

CORS_ORIGIN=https://your-app.vercel.app

RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW=900000

FFMPEG_PATH=ffmpeg
THUMBNAIL_COUNT=5
