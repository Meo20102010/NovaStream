# Vercel-only deployment environment variables
# Copy this file to .env.local for local development
# Or set these in Vercel Dashboard > Project Settings > Environment Variables

# Required: PostgreSQL database connection string
# For Vercel Postgres, use the connection string provided in the dashboard
DATABASE_URL="postgresql://user:password@host:5432/database?sslmode=require"

# Required: Secret key for JWT signing (use a strong random string)
JWT_SECRET="your-super-secret-jwt-key-change-in-production"

# Optional: Public site URL used for shareable video stream links
# Leave empty to auto-detect from the browser (window.location.origin)
NEXT_PUBLIC_SITE_URL=""

# Required: Vercel Blob read-write token for video storage
# Get this from Vercel Dashboard > Storage > Blob > Connect to Project
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_xxxxxxxxxxxxxxxxxxxx"

# Optional: Redis URL for caching/rate limiting
# If not set, Redis features are disabled (no rate limiting degradation)
REDIS_URL=""

# Optional: Node environment
NODE_ENV="production"
